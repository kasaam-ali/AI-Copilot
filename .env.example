# Copy this file to backend/.env and fill in the values you need.
# For a fully offline run, leave LLM_PROVIDER_ORDER=mock.

# --- Application ---
APP_API_KEY=change-me
ARTIFACT_ROOT=./artifacts
DATABASE_URL=sqlite:///./app.db

# --- LLM provider fallback chain ---
# Comma-separated list, tried left to right. "mock" is the deterministic
# offline terminal and should stay last so the app never fails without keys.
# Example with keys: LLM_PROVIDER_ORDER=groq,gemini,openrouter,zai,mock
LLM_PROVIDER_ORDER=mock

# Groq (OpenAI-compatible)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# z.AI (OpenAI-compatible) - set the base URL from your z.AI dashboard
ZAI_API_KEY=
ZAI_MODEL=
ZAI_BASE_URL=
